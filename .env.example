# Optional overrides — copy to .env and edit.
# Without .env: docker compose uses .env.default + inline defaults.

POSTGRES_USER=mikov
POSTGRES_PASSWORD=mikov
POSTGRES_DB=mikov

JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=models
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_BASE_PATH=/storage

# Docker: http://localhost (frontend nginx :80)
# Dev: npm run dev on :5173, API proxy via vite

VITE_YANDEX_MAPS_API_KEY=

# Nominatim (OSM) — free geocoding, no API key
NOMINATIM_USER_AGENT=mikov-cottages/1.0 (your@email.com)
